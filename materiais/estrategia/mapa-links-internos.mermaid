graph TB
    subgraph SAUDE["🏥 CLUSTER 1 — SAÚDE"]
        A1["#1 Médico"]
        A2["#2 Dentista"]
        A3["#3 Psicólogo ⬢HUB"]
        A4["#4 Nutricionista"]
        A5["#5 Fisioterapeuta"]
        A6["#6 Veterinário"]
        A7["#7 Terapeuta"]
        A8["#8 Esteticista"]
    end

    subgraph B2B["💼 CLUSTER 2 — NEGÓCIOS B2B"]
        B9["#9 Advogado"]
        B10["#10 Contador ⬢HUB"]
        B11["#11 Arquiteto"]
        B12["#12 Corretor de Imóveis"]
        B13["#13 Consultor ⬢HUB"]
        B14["#14 Programador"]
    end

    subgraph CRIATIVO["🎨 CLUSTER 3 — CRIATIVO"]
        C15["#15 Fotógrafo ★funil por data"]
        C16["#16 Videomaker"]
        C17["#17 Designer"]
        C18["#18 Social Media"]
        C19["#19 Copywriter"]
        C20["#20 Podcaster"]
        C21["#21 YouTuber ★lista própria"]
        C22["#22 Piloto de Drone ★checklist"]
    end

    subgraph ESTETICA["💅 CLUSTER 4 — ESTÉTICA"]
        D23["#23 Cabeleireiro ★régua de ciclo"]
        D24["#24 Maquiadora ★colheita"]
        D25["#25 Tatuador"]
    end

    subgraph EDUCACAO["🎓 CLUSTER 5 — EDUCAÇÃO"]
        E26["#26 Personal Trainer"]
        E27["#27 Professor"]
        E28["#28 Coach"]
        E29["#29 Mentor ⬢HUB"]
        E30["#30 Palestrante"]
    end

    subgraph DIGITAL["💻 MINI-CLUSTER DIGITAL"]
        F31["#31 Lançador/Infoprodutor ⭐A"]
        F32["#32 E-commerce ⭐A"]
    end

    %% ===== FRONTEIRAS LEGAIS (linhas cheias) =====
    A7 <--> A3
    A3 <--> E28
    A4 <--> E26
    A5 <--> E26
    A8 --> A5
    E27 --> A3

    %% ===== PARCERIAS DE NICHO =====
    A1 <--> A2
    A1 <--> A4
    B9 <--> B10
    B11 <--> B12
    B12 <--> C15
    B11 --> C15
    C15 <--> C16
    C15 <--> D24
    D23 <--> D24
    D23 --> A8
    D24 --> A8
    C17 <--> C18
    C18 <--> C19
    C17 <--> C19
    B14 --> C17
    C16 --> C21
    C22 --> C15
    C22 --> C16

    %% ===== TESES HERDADAS =====
    D25 -.->|checklist anti-clandestino| C22
    E28 -.->|checklist anti-charlatão| C22
    C20 <-.->|audiência alugada| C21
    C18 -.-> C21
    A2 -.->|régua de ciclo| D23
    A6 -.->|régua de ciclo| D23
    E26 -.->|régua anti-churn| D23
    E30 -.->|colheita do evento| D24
    E27 -.->|fuga do marketplace| A3

    %% ===== ESCADA DE VALOR =====
    B13 <--> E29
    B13 <--> E28
    E28 <--> E29
    B14 --> B13
    E30 --> E29
    E30 --> B13
    E30 --> C16

    %% ===== HUB CONTADOR (amostra dos principais) =====
    D23 --> B10
    D25 --> B10
    E27 --> B10
    E29 --> B10
    E30 --> B10
    F31 --> B10
    F32 --> B10

    %% ===== MINI-CLUSTER DIGITAL =====
    F31 <--> F32
    F31 --> E29
    F31 --> E28
    F31 --> C19
    F31 --> C18
    F32 --> C18
    F32 --> C19
    F32 --> C17
    C21 -.->|audiência alugada| F31
    D23 -.->|régua de ciclo → reposição| F32

    %% ===== ESTILOS =====
    classDef hub fill:#1e3a8a,stroke:#1e3a8a,color:#ffffff,stroke-width:3px
    classDef tese fill:#7c2d12,stroke:#7c2d12,color:#ffffff,stroke-width:2px
    classDef tierA fill:#c2410c,stroke:#c2410c,color:#ffffff,stroke-width:2px
    class A3,B10,B13,E29 hub
    class C15,C21,C22,D23,D24 tese
    class F31,F32 tierA
